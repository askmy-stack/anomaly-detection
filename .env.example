# Copy to .env and fill in values. LLM features are opt-in (llm.enabled: false by default).
ANTHROPIC_API_KEY=

# Optional: require X-API-Key on all API routes except /health, /docs, /redoc,
# and /openapi.json. Unset = open (dev) mode, no auth required.
ANOMALY_API_KEY=

# Optional: max rows accepted by /detect and /detect/batch. Defaults to 100000.
MAX_DETECT_ROWS=
